{
  "name": "freelens",
  "version": "2.0.0-0",
  "private": true,
  "description": "Freelens - Free IDE for Kubernetes",
  "keywords": [],
  "homepage": "https://freelens.app",
  "bugs": {
    "url": "https://github.com/freelensapp/freelens/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freelensapp/freelens.git"
  },
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Freelens Authors",
    "email": "freelens@freelens.app"
  },
  "main": "static/build/main.js",
  "scripts": {
    "build": "node --max-old-space-size=8192 node_modules/electron-vite/bin/electron-vite.js build",
    "prebuild:app": "node build/prebuild.cjs",
    "build:app": "pnpm dlx run-script-os@1.1.6 --",
    "build:app:darwin": "electron-builder --publish never --macos",
    "build:app:default": "electron-builder --publish never",
    "build:app:linux": "electron-builder --publish never --linux",
    "build:app:win32": "electron-builder --publish never --win",
    "build:dev": "NODE_ENV=development electron-vite build",
    "build:resources": "pnpm \"/^build:resources:/\"",
    "build:resources:client": "ensure-binaries --package package.json --base-dir binaries/client",
    "build:resources:license": "generate-license --prod --header license-header.txt --output static/build/license.txt",
    "build:resources:tray": "generate-tray-icons --output static/build/tray --input @freelensapp/icon/icons/logo-lens.svg --notice-icon @freelensapp/icon/icons/notice.svg --spinner-icon @freelensapp/icon/icons/arrow-spinner.svg --none-color fbfbfb",
    "clean:dist": "pnpm dlx rimraf@6.1.3 binaries dist static/build",
    "dev": "ELECTRON_RUN_AS_NODE= NODE_ENV=development electron-vite dev --watch --inspect --remoteDebuggingPort 9223",
    "start": "pnpm dlx run-script-os@1.1.6 --",
    "start:darwin": "pnpm start:darwin:${npm_config_arch:-$(uname -m)}",
    "start:darwin:arm64": "./dist/mac-arm64/Freelens.app/Contents/MacOS/Freelens",
    "start:darwin:x64": "./dist/mac/Freelens.app/Contents/MacOS/Freelens",
    "start:darwin:x86_64": "./dist/mac/Freelens.app/Contents/MacOS/Freelens",
    "start:default": "exit 1",
    "start:electron": "electron --remote-debugging-port=9223 --inspect .",
    "start:linux": "pnpm start:linux:${npm_config_arch:-$(uname -m)}",
    "start:linux:arm64": "./dist/linux-arm64-unpacked/freelens",
    "start:linux:x64": "./dist/linux-unpacked/freelens",
    "start:linux:x86_64": "./dist/linux-unpacked/freelens",
    "start:win32:AMD64": "dist\\win-unpacked\\Freelens.exe",
    "start:win32:ARM64": "dist\\win-arm64-unpacked\\Freelens.exe",
    "start:win32": "echo pnpm start:linux:${npm_config_arch:-${PROCESSOR_ARCHITECTURE}}",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "config": {
    "bundledHelmVersion": "4.2.3",
    "bundledKubectlVersion": "1.36.2",
    "contentSecurityPolicy": "script-src 'unsafe-eval' 'self'; frame-src https://*.renderer.freelens.app:*/; img-src * data:",
    "k8sProxyVersion": "1.8.1",
    "welcomeRoute": "/welcome"
  },
  "dependencies": {
    "@astronautlabs/jsonpath": "^1.1.2",
    "@freelensapp/application": "workspace:^",
    "@freelensapp/application-for-electron-main": "workspace:^",
    "@freelensapp/core": "workspace:^",
    "@freelensapp/feature-core": "workspace:^",
    "@freelensapp/kube-api-specifics": "workspace:^",
    "@freelensapp/logger": "workspace:^",
    "@freelensapp/messaging-for-main": "workspace:^",
    "@freelensapp/prometheus": "workspace:^",
    "@freelensapp/random": "workspace:^",
    "@hapi/call": "^9.0.1",
    "@hapi/subtext": "^8.1.3",
    "@kubernetes/client-node": "^1.4.0",
    "@ogre-tools/fp": "^17.11.1",
    "@ogre-tools/injectable": "^17.11.1",
    "@ogre-tools/injectable-extension-for-mobx": "^17.11.1",
    "auto-bind": "^5.0.1",
    "byline": "^5.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "conf": "^15.1.0",
    "electron-window-state": "^5.0.3",
    "fs-extra": "^11.3.6",
    "glob-to-regexp": "^0.4.1",
    "handlebars": "^4.7.9",
    "hpagent": "^1.2.0",
    "http-proxy-node16": "^1.0.6",
    "immer": "^11.1.8",
    "joi": "^18.2.3",
    "js-yaml": "^5.2.1",
    "mobx": "^6.15.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "node-fetch": "^3.3.2",
    "node-pty": "1.2.0-beta.14",
    "p-limit": "^7.3.0",
    "path-to-regexp": "^8.4.2",
    "pnpm": "^11.13.1",
    "proper-lockfile": "^4.1.2",
    "react": "^17.0.2",
    "react-router": "^5.3.4",
    "selfsigned": "^5.5.0",
    "semver": "^7.8.5",
    "stoppable": "^1.1.0",
    "tar": "^7.5.19",
    "tcp-port-used": "^1.0.3",
    "tempy": "3.2.0",
    "triple-beam": "^1.4.1",
    "typed-regex": "^0.0.8",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@freelensapp/animate": "workspace:^",
    "@freelensapp/button": "workspace:^",
    "@freelensapp/cluster-sidebar": "workspace:^",
    "@freelensapp/ensure-binaries": "workspace:^",
    "@freelensapp/error-boundary": "workspace:^",
    "@freelensapp/generate-license": "workspace:^",
    "@freelensapp/generate-tray-icons": "workspace:^",
    "@freelensapp/icon": "workspace:^",
    "@freelensapp/keyboard-shortcuts": "workspace:^",
    "@freelensapp/messaging-for-renderer": "workspace:^",
    "@freelensapp/notifications": "workspace:^",
    "@freelensapp/react-application": "workspace:^",
    "@freelensapp/resizing-anchor": "workspace:^",
    "@freelensapp/routing": "workspace:^",
    "@freelensapp/spinner": "workspace:^",
    "@freelensapp/test-utils": "workspace:^",
    "@freelensapp/tooltip": "workspace:^",
    "@freelensapp/utilities": "workspace:^",
    "@ogre-tools/injectable-react": "^17.11.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "~24.12.4",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "^42.7.0",
    "electron-builder": "26.15.6",
    "electron-builder-squirrel-windows": "26.15.6",
    "electron-vite": "6.0.0-beta.1",
    "playwright": "^1.61.1",
    "sass-embedded": "1.100.0",
    "typescript": "^7.0.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "copyright": "© 2024-2026 Freelens Authors",
  "productName": "Freelens"
}
