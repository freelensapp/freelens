{
  "name": "@freelensapp/extensions",
  "version": "1.10.4-0",
  "description": "Freelens - Free IDE for Kubernetes: extensions",
  "homepage": "https://freelens.app",
  "bugs": {
    "url": "https://github.com/freelensapp/freelens/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freelensapp/freelens.git"
  },
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Freelens Authors",
    "email": "freelens@freelens.app"
  },
  "main": "./src/extension-api.ts",
  "types": "./src/extension-api.ts",
  "files": [
    "dist/extension-api.js",
    "dist/extension-api.d.ts",
    "__mocks__/*.ts"
  ],
  "scripts": {
    "build:dist": "pnpm build:dist:declarations && pnpm build:dist:bundle && pnpm build:dist:shim",
    "build:dist:declarations": "node scripts/generate-dts-tsconfig.mjs && tsc -p tsconfig.dts.generated.json",
    "build:dist:bundle": "rollup -c rollup.dts.config.mjs",
    "build:dist:shim": "node scripts/build-shim.mjs",
    "clean": "pnpm dlx rimraf@6.1.3 dist dist-types",
    "clean:node_modules": "pnpm dlx rimraf@6.1.3 node_modules",
    "prepack": "pnpm build:dist"
  },
  "devDependencies": {
    "@freelensapp/core": "workspace:^",
    "@types/node": "~24.12.4",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.9.3",
    "typescript-plugin-css-modules": "^5.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "main": "./dist/extension-api.js",
    "types": "./dist/extension-api.d.ts",
    "exports": {
      ".": {
        "types": "./dist/extension-api.d.ts",
        "default": "./dist/extension-api.js"
      },
      "./package.json": "./package.json"
    }
  },
  "copyright": "© 2024-2026 Freelens Authors",
  "productName": "Freelens extensions"
}
