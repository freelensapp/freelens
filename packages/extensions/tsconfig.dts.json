{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": false,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "rootDir": "../..",
    "outDir": "dist-types"
  },
  "include": ["src/**/*", "../core/types/*.d.ts"]
}
